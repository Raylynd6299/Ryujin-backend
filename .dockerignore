# Backend .dockerignore for Ryujin

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
main

# Test files
*.test

# Output of the go coverage tool
*.out

# Dependency directories
vendor/

# Go workspace file
go.work

# Environment files
.env
.env.*
!.env.example

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation
*.md
!README.md

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
